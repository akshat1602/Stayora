<!-- EJS-mate -->
<% layout("/layouts/boilerplate") %>

<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listingData = <%- JSON.stringify(listing) %>;
</script>

<%
    const safeReviews = Array.isArray(listing.reviews) ? listing.reviews : [];
    const safeBookings = Array.isArray(listing.bookings) ? listing.bookings : [];
    const listingImageUrl = listing.image && (listing.image.url || listing.image.secure_url || listing.image.path || listing.image);
    const isOwner = currUser && listing.owner && listing.owner._id.equals(currUser._id);
%>

<div class="show-wrapper mt-3">
    <div class="show-grid">
        <div class="show-main">
            <div class="show-content">
                <div class="show-header">
                    <h3><%= listing.title %></h3>
                    <p class="show-subtitle">
                        <i class="fa-solid fa-location-dot"></i>
                        <span><%= listing.location %>, <%= listing.country %></span>
                    </p>
                </div>

                <div class="card show-card listing-card">
                    <div class="card show-inner-card">
                        <img src="<%= listingImageUrl %>" class="card-img-top show-img" alt="listing_image">

                        <div class="card-body">
                            <div class="show-meta-top">
                                <span class="show-price">
                                    &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                </span>
                                <span class="show-price-unit">/ night</span>
                            </div>

                            <div class="show-host-line">
                                <span class="show-label">Hosted by</span>
                                <span class="show-host-name"><%= listing.owner.username %></span>
                            </div>

                            <p class="card-text show-description">
                                <%= listing.description %>
                            </p>
                        </div>
                    </div>
                </div>

                <% if (currUser && !isOwner) { %>
                    <div class="wishlist-btn-wrapper mb-3">
                        <% if (isWishlisted) { %>
                            <form method="POST" action="/listings/<%= listing._id %>/wishlist?_method=DELETE">
                                <button class="btn btn-dark wishlist-action-btn">Remove from Wishlist</button>
                            </form>
                        <% } else { %>
                            <form method="POST" action="/listings/<%= listing._id %>/wishlist">
                                <button class="btn btn-outline-dark wishlist-action-btn">Save to Wishlist</button>
                            </form>
                        <% } %>
                    </div>
                <% } %>

                <% if (isOwner) { %>
                    <div class="btns">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>

                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                            <button class="btn btn-dark">Delete</button>
                        </form>
                    </div>
                <% } %>

                <div class="map-wrapper mb-3">
                    <h3>Where you'll be</h3>
                    <div id="map"></div>
                </div>
            </div>
        </div>

        <aside class="show-review">
            <div class="card show-card">
                <div class="card show-inner-card">
                    <div class="card-body">

                        <div class="review-summary-box">
                            <h4>Stay snapshot</h4>
                            <div class="review-summary-items">
                                <div class="review-summary-item">
                                    <span class="summary-label">Price</span>
                                    <span class="summary-value">
                                        &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %>/night
                                    </span>
                                </div>
                                <div class="review-summary-item">
                                    <span class="summary-label">Reviews</span>
                                    <span class="summary-value"><%= safeReviews.length %> total</span>
                                </div>
                                <div class="review-summary-item">
                                    <span class="summary-label">Location</span>
                                    <span class="summary-value"><%= listing.location %></span>
                                </div>
                            </div>
                        </div>

                        <% if (currUser && !isOwner) { %>
                            <div class="booking-box mb-4">
                                <div class="booking-box-head">
                                    <h4>Book this stay</h4>
                                    <p class="booking-subtext">
                                        Select your stay dates to check availability.
                                    </p>
                                </div>

                                <form action="/listings/<%= listing._id %>/bookings" method="POST" novalidate class="needs-validation stayora-form booking-form">
                                    <div class="mb-3">
                                        <label for="checkIn" class="form-label">Check-in</label>
                                        <input
                                            type="date"
                                            id="checkIn"
                                            name="checkIn"
                                            class="form-control"
                                            required
                                        >
                                        <div class="invalid-feedback">
                                            Please select a valid check-in date.
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label for="checkOut" class="form-label">Check-out</label>
                                        <input
                                            type="date"
                                            id="checkOut"
                                            name="checkOut"
                                            class="form-control"
                                            required
                                        >
                                        <div class="invalid-feedback">
                                            Please select a valid check-out date.
                                        </div>
                                    </div>

                                    <button class="btn btn-dark w-100 booking-btn">Reserve</button>
                                </form>

                                <% if (safeBookings.length > 0) { %>
                                    <div class="booked-dates-note mt-3">
                                        <p class="mb-2"><b>Booked dates unavailable:</b></p>
                                        <ul class="mb-0 ps-3">
                                            <% safeBookings.forEach((booking) => { %>
                                                <li>
                                                    <%= new Date(booking.checkIn).toLocaleDateString("en-IN", {
                                                        day: "numeric",
                                                        month: "short",
                                                        year: "numeric"
                                                    }) %>
                                                    -
                                                    <%= new Date(booking.checkOut).toLocaleDateString("en-IN", {
                                                        day: "numeric",
                                                        month: "short",
                                                        year: "numeric"
                                                    }) %>
                                                </li>
                                            <% }) %>
                                        </ul>
                                    </div>
                                <% } else { %>
                                    <div class="booked-dates-note mt-3">
                                        <p class="mb-0">No dates are booked yet for this stay.</p>
                                    </div>
                                <% } %>
                            </div>

                            <hr class="my-4 review-sep">
                        <% } %>

                        <% if (currUser) { %>
                            <div class="review-form-box">
                                <div class="review-form-head">
                                    <h4>Leave a Review</h4>
                                    <p class="review-form-subtext">
                                        Share your stay experience to help future guests.
                                    </p>
                                </div>

                                <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation stayora-form review-form">
                                    <div class="mb-3 mt-3">
                                        <label for="rating" class="form-label">Rating</label>

                                        <fieldset class="starability-slot">
                                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                            <label for="first-rate1" title="Terrible">1 star</label>

                                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                            <label for="first-rate2" title="Not good">2 stars</label>

                                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                            <label for="first-rate3" title="Average">3 stars</label>

                                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                            <label for="first-rate4" title="Very good">4 stars</label>

                                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                            <label for="first-rate5" title="Amazing">5 stars</label>
                                        </fieldset>

                                        <div class="form-helper-text">Choose a rating before submitting your review.</div>
                                    </div>

                                    <div class="mb-3 mt-3">
                                        <label for="comment" class="form-label">Comments</label>
                                        <textarea
                                            name="review[comment]"
                                            id="comment"
                                            cols="30"
                                            rows="5"
                                            class="form-control review-textarea"
                                            required
                                            placeholder="Share what you liked about this stay"
                                        ></textarea>
                                        <div class="invalid-feedback">Please add some comments for review.</div>
                                    </div>

                                    <button class="btn btn-outline-dark review-submit-btn">Submit</button>
                                </form>
                            </div>

                            <hr class="my-4 review-sep">
                        <% } %>

                        <% if (safeReviews.length > 0) { %>
                            <div class="review-section">
                                <p class="review-title"><b>Guest Reviews</b></p>

                                <div class="row g-3 review-row">
                                    <% for (let review of safeReviews) { %>
                                        <% const canDeleteReview = currUser && review.author && (review.author._id.equals(currUser._id) || isOwner); %>
                                        <div class="col-12">
                                            <div class="card review-card h-100">
                                                <div class="card-body">
                                                    <div class="review-card-top">
                                                        <h5 class="card-title">@<%= review.author.username %></h5>
                                                        <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                                    </div>

                                                    <p class="card-text review-comment">
                                                        <%= review.comment %>
                                                    </p>

                                                    <% if (canDeleteReview) { %>
                                                        <form class="mb-0" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                            <button class="btn btn-sm btn-dark review-delete-btn">Delete</button>
                                                        </form>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="review-empty-state">
                                <div class="review-empty-icon">
                                    <i class="fa-regular fa-message"></i>
                                </div>
                                <h5>No reviews yet</h5>
                                <p>Be the first guest to share an experience for this stay.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<script>
    const today = new Date().toISOString().split("T")[0];
    const checkInInput = document.getElementById("checkIn");
    const checkOutInput = document.getElementById("checkOut");

    if (checkInInput && checkOutInput) {
        checkInInput.min = today;
        checkOutInput.min = today;

        checkInInput.addEventListener("change", function () {
            checkOutInput.min = this.value;
            if (checkOutInput.value && checkOutInput.value <= this.value) {
                checkOutInput.value = "";
            }
        });
    }
</script>

<script src="/JS/map.js"></script>