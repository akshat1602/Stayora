<% layout("/layouts/boilerplate") %>

<%
    const safeWishlist = Array.isArray(wishlist) ? wishlist : [];
%>

<div class="container mt-4">
    <h2 class="mb-4">My Wishlist</h2>

    <% if (safeWishlist.length === 0) { %>
        <div class="wishlist-empty text-center">
            <div class="wishlist-empty-icon">
                <i class="fa-regular fa-heart" aria-hidden="true"></i>
            </div>
            <h4>No saved listings yet</h4>
            <p>
                Start exploring stays and save the ones you’d love to revisit.
            </p>
            <a href="/listings" class="btn btn-danger wishlist-empty-btn">Explore listings</a>
        </div>
    <% } else { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
            <% for (let listing of safeWishlist) { %>
                <% const listingImageUrl = listing.image && (listing.image.url || listing.image.secure_url || listing.image.path || listing.image); %>
                <div class="col">
                    <div class="card listing-card h-100">
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <img src="<%= listingImageUrl %>" class="card-img-top" alt="listing_image">

                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b>
                                    <br>
                                    &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
                                </p>
                            </div>
                        </a>

                        <div class="card-body pt-0">
                            <form method="POST" action="/listings/<%= listing._id %>/wishlist?_method=DELETE">
                                <button class="btn btn-sm btn-dark">Remove</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>