<% layout("/layouts/boilerplate") %>

<div class="container mt-4">
    <h2 class="mb-4">My Wishlist</h2>

    <% if (wishlist.length === 0) { %>
        <p>No saved listings yet.</p>
    <% } else { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
            <% for (let listing of wishlist) { %>
                <div class="col">
                    <div class="card listing-card h-100">
                        
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">

                            <div class="card-body">
                                <p class="card-text">
                                    <b><%= listing.title %></b>
                                    <br>
                                    &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %> / night
                                </p>
                            </div>
                        </a>

                        <div class="card-body pt-0">
                            <form method="POST" action="/listings/<%= listing._id %>/wishlist?_method=DELETE">
                                <button class="btn btn-sm btn-dark">Remove</button>
                            </form>
                        </div>

                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>