<!-- EJS-mate -->
<% layout("/layouts/boilerplate") %>

<div class="edit-wrapper mt-3">
    <div class="edit-form-container form-shell">
        <div class="form-page-header">
            <span class="form-page-eyebrow">Update your stay</span>
            <h3>Edit Your Listing</h3>
            <p class="form-page-subtitle">
                Refine the details below to keep your listing accurate and attractive to guests.
            </p>
        </div>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation stayora-form" enctype="multipart/form-data">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input name="listing[title]" value="<%= listing.title %>" type="text" class="form-control <%= error && error.errors && error.errors.title ? 'is-invalid' : '' %>" required>
                <div class="invalid-feedback">Please enter a title.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control edit-textarea <%= error && error.errors && error.errors.description ? 'is-invalid' : '' %>" required><%= listing.description %></textarea>
                <div class="invalid-feedback">Please enter a description.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <!-- Category of listing -->
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select
                    name="listing[category]"
                    class="form-select <%= error && error.errors && error.errors.category ? 'is-invalid' : '' %>"
                    required
                >
                    <option value="">Select a category</option>
                    <option value="Trending" <%= listing.category === "Trending" ? "selected" : "" %>>Trending</option>
                    <option value="Rooms" <%= listing.category === "Rooms" ? "selected" : "" %>>Rooms</option>
                    <option value="Iconic cities" <%= listing.category === "Iconic cities" ? "selected" : "" %>>Iconic cities</option>
                    <option value="Mountains" <%= listing.category === "Mountains" ? "selected" : "" %>>Mountains</option>
                    <option value="Castles" <%= listing.category === "Castles" ? "selected" : "" %>>Castles</option>
                    <option value="Amazing Pools" <%= listing.category === "Amazing Pools" ? "selected" : "" %>>Amazing Pools</option>
                    <option value="Camping" <%= listing.category === "Camping" ? "selected" : "" %>>Camping</option>
                    <option value="Farms" <%= listing.category === "Farms" ? "selected" : "" %>>Farms</option>
                    <option value="Arctic" <%= listing.category === "Arctic" ? "selected" : "" %>>Arctic</option>
                    <option value="Domes" <%= listing.category === "Domes" ? "selected" : "" %>>Domes</option>
                    <option value="Beaches" <%= listing.category === "Beaches" ? "selected" : "" %>>Beaches</option>
                </select>
                <div class="invalid-feedback">Please select a category.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <!-- current image preview shown below -->
            <div class="mb-3">
                <label class="form-label d-block">Original Listing Image</label><br>

                <% if (originalImageUrl || (listing.image && listing.image.url)) { %>
                    <img id="currentImagePreview" src="<%= originalImageUrl ? originalImageUrl : (listing.image && listing.image.url ? listing.image.url : '') %>" class="card-img-top edit-preview-img mb-3" alt="current listing image">
                <% } else { %>
                    <img id="currentImagePreview" src="" class="card-img-top edit-preview-img mb-3" alt="preview" style="display:none;">
                <% } %>

                <label for="image" class="form-label">Upload New Image</label>
                <input id="imageInput" name="listing[image]" type="file" class="form-control <%= error && error.errors && error.errors.image ? 'is-invalid' : '' %>">
                <div class="form-helper-text">Upload a new image only if you want to replace the current one.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input name="listing[price]" value="<%= (listing.price || listing.price === 0) ? listing.price : '' %>" type="number" min="0" step="1" class="form-control <%= error && error.errors && error.errors.price ? 'is-invalid' : '' %>" required>
                    <div class="invalid-feedback">Please enter a valid non-negative price.</div>
                    <div class="valid-feedback">Looks good!</div>
                </div>

                <div class="col-12 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" value="<%= listing.country %>" type="text" class="form-control <%= error && error.errors && error.errors.country ? 'is-invalid' : '' %>" required>
                    <div class="invalid-feedback">Please enter a country.</div>
                    <div class="valid-feedback">Looks good!</div>
                </div>
            </div>

            <div class="mb-3 mt-3">
                <label for="location" class="form-label">Location</label>
                <input name="listing[location]" value="<%= listing.location %>" type="text" class="form-control <%= error && error.errors && error.errors.location ? 'is-invalid' : '' %>" required>
                <div class="invalid-feedback">Please enter a location.</div>
                <div class="valid-feedback">Looks good!</div>
            </div>

            <button class="btn btn-dark edit-btn mt-3 edit-submit-btn">Save Changes</button>
        </form>

    </div>
</div>

<script>
    // Client-side preview of selected image file
    const imageInput = document.getElementById('imageInput');
    const preview = document.getElementById('currentImagePreview');

    if(imageInput){
        imageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if(!file) return;
            const reader = new FileReader();
            reader.onload = function(evt){
                preview.src = evt.target.result;
                preview.style.display = 'block';
            }
            reader.readAsDataURL(file);
        });
    }
</script>