<!-- EJS-mate -->
<% layout("/layouts/boilerplate") %>

<form action="/listings" method="GET" class="search-filter-box">
    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-3">
            <label for="search" class="form-label">Search</label>
            <input
                type="text"
                id="search"
                name="search"
                class="form-control"
                placeholder="Search by title, location, country"
                value="<%= filters && filters.search ? filters.search : '' %>"
            >
        </div>

        <div class="col-6 col-md-3 col-lg-2">
            <label for="minPrice" class="form-label">Min Price</label>
            <input
                type="number"
                id="minPrice"
                name="minPrice"
                min="0"
                class="form-control"
                value="<%= filters && filters.minPrice ? filters.minPrice : '' %>"
            >
        </div>

        <div class="col-6 col-md-3 col-lg-2">
            <label for="maxPrice" class="form-label">Max Price</label>
            <input
                type="number"
                id="maxPrice"
                name="maxPrice"
                min="0"
                class="form-control"
                value="<%= filters && filters.maxPrice ? filters.maxPrice : '' %>"
            >
        </div>

        <div class="col-12 col-md-6 col-lg-2">
            <label for="sort" class="form-label">Sort</label>
            <select id="sort" name="sort" class="form-select">
                <option value="">Newest</option>
                <option value="price_asc" <%= filters && filters.sort === "price_asc" ? "selected" : "" %>>Price: Low to High</option>
                <option value="price_desc" <%= filters && filters.sort === "price_desc" ? "selected" : "" %>>Price: High to Low</option>
            </select>
        </div>

        <div class="col-12 col-md-6 col-lg-3 d-flex align-items-end">
            <div class="filter-actions w-100">
                <button class="btn btn-dark">Apply</button>
                <a href="/listings" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<%
    const safeListings = Array.isArray(allListings) ? allListings : [];
    const currentSearch = filters && filters.search ? filters.search : "";
    const currentMinPrice = filters && filters.minPrice ? filters.minPrice : "";
    const currentMaxPrice = filters && filters.maxPrice ? filters.maxPrice : "";
    const currentSort = filters && filters.sort ? filters.sort : "";
    const currentCategory = filters && filters.category ? filters.category : "";

    const hasSearch = currentSearch.trim() !== "";
    const hasCategory = currentCategory.trim() !== "";
    const hasMinPrice = currentMinPrice !== "";
    const hasMaxPrice = currentMaxPrice !== "";
    const hasSort = currentSort.trim() !== "";

    const hasActiveSearch = hasSearch;
    const hasOtherFilters = hasCategory || hasMinPrice || hasMaxPrice || hasSort;
    const hasActiveFilters = hasSearch || hasCategory || hasMinPrice || hasMaxPrice || hasSort;
%>

<%
    function buildCategoryUrl(categoryName) {
        const params = new URLSearchParams();

        if (hasSearch) params.set("search", currentSearch);
        if (hasMinPrice) params.set("minPrice", currentMinPrice);
        if (hasMaxPrice) params.set("maxPrice", currentMaxPrice);
        if (hasSort) params.set("sort", currentSort);

        if (!hasCategory || currentCategory !== categoryName) {
            params.set("category", categoryName);
        }

        const queryString = params.toString();
        return queryString ? `/listings?${queryString}` : "/listings";
    }

    function buildRemoveFilterUrl(keyToRemove) {
        const params = new URLSearchParams();

        if (hasSearch) params.set("search", currentSearch);
        if (hasCategory) params.set("category", currentCategory);
        if (hasMinPrice) params.set("minPrice", currentMinPrice);
        if (hasMaxPrice) params.set("maxPrice", currentMaxPrice);
        if (hasSort) params.set("sort", currentSort);

        params.delete(keyToRemove);

        const queryString = params.toString();
        return queryString ? `/listings?${queryString}` : "/listings";
    }
%>

<% if (hasActiveFilters) { %>
    <div class="results-summary">
        <% if (hasActiveSearch) { %>
            <h5>Results for "<%= currentSearch %>"</h5>
        <% } else { %>
            <h5>Filtered listings</h5>
        <% } %>

        <p>
            <strong><%= safeListings.length %></strong> listing<%= safeListings.length === 1 ? "" : "s" %> found.
            <a href="/listings">Clear all filters</a>
        </p>
    </div>
<% } %>

<% if (hasActiveFilters) { %>
    <div class="active-filters">
        <% if (hasSearch) { %>
            <a href="<%= buildRemoveFilterUrl('search') %>" class="filter-chip">
                Search: <%= currentSearch %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasCategory) { %>
            <a href="<%= buildRemoveFilterUrl('category') %>" class="filter-chip">
                Category: <%= currentCategory %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasMinPrice) { %>
            <a href="<%= buildRemoveFilterUrl('minPrice') %>" class="filter-chip">
                Min: ₹<%= Number(currentMinPrice).toLocaleString("en-IN") %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasMaxPrice) { %>
            <a href="<%= buildRemoveFilterUrl('maxPrice') %>" class="filter-chip">
                Max: ₹<%= Number(currentMaxPrice).toLocaleString("en-IN") %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasSort) { %>
            <a href="<%= buildRemoveFilterUrl('sort') %>" class="filter-chip">
                Sort:
                <%= currentSort === "price_asc" ? "Price: Low to High" : currentSort === "price_desc" ? "Price: High to Low" : currentSort %>
                <span>&times;</span>
            </a>
        <% } %>

        <a href="/listings" class="clear-all-chip">Clear all</a>
    </div>
<% } %>

<div class="filters-toolbar">
    <div id="filters">
        <a href="<%= buildCategoryUrl('Trending') %>" class="filter <%= currentCategory === 'Trending' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>

        <a href="<%= buildCategoryUrl('Rooms') %>" class="filter <%= currentCategory === 'Rooms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </a>

        <a href="<%= buildCategoryUrl('Iconic cities') %>" class="filter <%= currentCategory === 'Iconic cities' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic cities</p>
        </a>

        <a href="<%= buildCategoryUrl('Mountains') %>" class="filter <%= currentCategory === 'Mountains' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>

        <a href="<%= buildCategoryUrl('Castles') %>" class="filter <%= currentCategory === 'Castles' ? 'active-filter' : '' %>">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </a>

        <a href="<%= buildCategoryUrl('Amazing Pools') %>" class="filter <%= currentCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </a>

        <a href="<%= buildCategoryUrl('Camping') %>" class="filter <%= currentCategory === 'Camping' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>

        <a href="<%= buildCategoryUrl('Farms') %>" class="filter <%= currentCategory === 'Farms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-tractor"></i></div>
            <p>Farms</p>
        </a>

        <a href="<%= buildCategoryUrl('Arctic') %>" class="filter <%= currentCategory === 'Arctic' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>

        <a href="<%= buildCategoryUrl('Domes') %>" class="filter <%= currentCategory === 'Domes' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-landmark-dome"></i></div>
            <p>Domes</p>
        </a>

        <a href="<%= buildCategoryUrl('Beaches') %>" class="filter <%= currentCategory === 'Beaches' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-umbrella-beach"></i></div>
            <p>Beaches</p>
        </a>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>

<p class="filters-hint">Swipe for more filters →</p>

<% if (safeListings.length === 0) { %>
    <div class="empty-state-box">
        <% if (hasActiveSearch) { %>
            <h5>No listings found for "<%= currentSearch %>"</h5>
            <p>Try a different keyword, remove some filters, or browse all listings instead.</p>
            <div class="empty-state-actions">
                <a href="<%= buildRemoveFilterUrl('search') %>" class="btn btn-outline-dark btn-sm">Clear search</a>
                <a href="/listings" class="btn btn-dark btn-sm">Browse all listings</a>
            </div>
        <% } else if (hasOtherFilters) { %>
            <h5>No listings match these filters</h5>
            <p>Try changing the category, price range, or sorting options to discover more stays.</p>
            <div class="empty-state-actions">
                <a href="/listings" class="btn btn-dark btn-sm">Clear filters</a>
            </div>
        <% } else { %>
            <h5>No listings found</h5>
            <p>There are no listings to show right now. Check back later or create a new one.</p>
            <div class="empty-state-actions">
                <a href="/listings/new" class="btn btn-dark btn-sm">Create listing</a>
            </div>
        <% } %>
    </div>
<% } %>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 listing-row">
    <% for (let listing of safeListings) { %>
        <% const listingImageUrl = listing.image && (listing.image.url || listing.image.secure_url || listing.image.path || listing.image); %>
        <div class="col">
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card listing-card h-100">
                    <div class="listing-image-wrap">
                        <img
                            src="<%= listingImageUrl %>"
                            class="card-img-top"
                            alt="listing_image"
                        >
                        <div class="card-img-overlay"></div>
                    </div>

                    <div class="card-body">
                        <h5 class="listing-title"><%= listing.title %></h5>

                        <p class="listing-meta">
                            <%= listing.location %>, <%= listing.country %>
                        </p>

                        <div class="listing-bottom">
                            <p class="listing-price">
                                &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                <span>/ night</span>
                                <i class="tax-info">&nbsp; +18% GST</i>
                            </p>

                            <% if (listing.category) { %>
                                <span class="listing-tag"><%= listing.category %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    if (taxSwitch) {
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (let info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        });
    }
</script>