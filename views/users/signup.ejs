<% layout("/layouts/boilerplate") %>

<section class="auth-section">
    <div class="auth-shell">
        <div class="auth-card">
            <div class="auth-copy">
                <span class="auth-eyebrow">Join Stayora</span>
                <h1 class="auth-title">Sign up on Stayora</h1>
                <p class="auth-subtitle">
                    Create your account to save wishlist items, post reviews, and plan your next memorable stay.
                </p>
            </div>

            <form action="/signup" method="POST" class="needs-validation auth-form" novalidate>

                <!-- Username -->
                <div class="auth-field">
                    <label for="username" class="form-label auth-label">Username</label>
                    <input
                        name="username"
                        type="text"
                        id="username"
                        class="form-control auth-input"
                        value="<%= formData && formData.username ? formData.username : '' %>"
                        autocomplete="username"
                        required
                    />
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        Please enter a username.
                    </div>
                </div>

                <!-- Email -->
                <div class="auth-field">
                    <label for="email" class="form-label auth-label">Email</label>
                    <input
                        name="email"
                        type="email"
                        id="email"
                        class="form-control auth-input"
                        value="<%= formData && formData.email ? formData.email : '' %>"
                        autocomplete="email"
                        required
                    />
                    <div class="invalid-feedback">
                        Please enter a valid email.
                    </div>
                </div>

                <!-- Password -->
                <div class="auth-field">
                    <label for="password" class="form-label auth-label">Password</label>
                    <input
                        name="password"
                        type="password"
                        id="password"
                        class="form-control auth-input"
                        autocomplete="new-password"
                        required
                    />
                    <div class="auth-helper-text">
                        Use a secure password that you can remember easily.
                    </div>
                    <div class="invalid-feedback">
                        Please enter a password.
                    </div>
                </div>

                <button class="btn auth-submit-btn">SignUp</button>

                <p class="auth-switch-text">
                    Already have an account?
                    <a href="/login" class="auth-switch-link">Login here</a>
                </p>
            </form>
        </div>
    </div>
</section>