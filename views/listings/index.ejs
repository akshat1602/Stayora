<!-- EJS-mate -->
<% layout("/layouts/boilerplate") %>

<style>
    .search-filter-box {
        background: #ffffff;
        border: 1px solid #e6e6e6;
        border-radius: 1.35rem;
        padding: 1rem 1rem 0.95rem;
        margin: 1rem auto 1.2rem;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.05);
    }

    .search-filter-box .form-label {
        font-weight: 600;
        margin-bottom: 0.45rem;
        color: #222222;
        font-size: 0.93rem;
    }

    .search-filter-box .form-control,
    .search-filter-box .form-select {
        border-radius: 0.95rem;
        min-height: 2.95rem;
        border: 1px solid #d8d8d8;
        box-shadow: none;
        padding-left: 0.9rem;
        padding-right: 0.9rem;
    }

    .search-filter-box .form-control:focus,
    .search-filter-box .form-select:focus {
        border-color: #222222;
        box-shadow: 0 0 0 0.12rem rgba(34, 34, 34, 0.08);
    }

    .search-filter-box .row {
        align-items: end;
    }

    .filter-actions {
        display: flex;
        gap: 0.85rem;
        width: 100%;
        flex-wrap: nowrap;
    }

    .filter-actions .btn {
        border-radius: 0.9rem;
        min-height: 2.95rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        line-height: 1;
        padding: 0 1.1rem;
        white-space: nowrap;
        flex: 1;
    }

    .filter-actions .btn-dark {
        border: 1px solid #212529;
    }

    .filter-actions .btn-outline-secondary {
        border: 1px solid #b8b8b8;
        color: #555555;
    }

    .results-summary {
        max-width: 1120px;
        margin: 0.3rem auto 0.8rem;
        padding: 0 0.1rem;
    }

    .results-summary h5 {
        margin-bottom: 0.22rem;
        color: #1f1f1f;
        font-weight: 700;
        letter-spacing: -0.01em;
    }

    .results-summary p {
        margin-bottom: 0;
        color: #6b6b6b;
        font-size: 0.95rem;
    }

    .results-summary a {
        color: #222222;
        font-weight: 600;
    }

    .active-filters {
        max-width: 1120px;
        margin: 0 auto 1rem;
        padding: 0 0.1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
    }

    .filter-chip,
    .clear-all-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.48rem 0.88rem;
        border-radius: 999px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .filter-chip {
        background: #f5f5f5;
        color: #222222;
        border: 1px solid #e0e0e0;
    }

    .filter-chip:hover {
        background: #ececec;
        color: #111111;
    }

    .filter-chip span {
        font-size: 1rem;
        line-height: 1;
    }

    .clear-all-chip {
        background: #212529;
        color: #ffffff;
        border: 1px solid #212529;
    }

    .clear-all-chip:hover {
        background: #111111;
        color: #ffffff;
    }

    .filters-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.25rem;
        margin-top: 0.15rem;
        margin-bottom: 0.4rem;
    }

    #filters {
        display: flex;
        align-items: flex-start;
        gap: 1.6rem;
        overflow-x: auto;
        white-space: nowrap;
        padding: 0 0.35rem 0.85rem;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
        flex: 1;
        min-width: 0;
    }

    #filters::-webkit-scrollbar {
        display: none;
    }

    #filters::after {
        content: "";
        display: block;
        min-width: 0.5rem;
        flex: 0 0 auto;
    }

    .filters-hint {
        display: none;
        font-size: 0.75rem;
        color: #777;
        margin: 0.1rem 0 0.8rem 0.25rem;
    }

    .filter {
        text-align: center;
        opacity: 0.78;
        min-width: 96px;
        flex: 0 0 auto;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
        transform: translateY(-1px);
    }

    .filter.active-filter {
        opacity: 1;
    }

    .filter.active-filter i,
    .filter.active-filter p {
        color: #fe424d;
        font-weight: 600;
    }

    .filter i {
        font-size: 1rem;
        margin-bottom: 0.35rem;
    }

    .filter p {
        font-size: 0.76rem;
        line-height: 1.25;
        margin: 0;
        white-space: normal;
    }

    .tax-info {
        display: none;
    }

    .tax-toggle {
        border: 1px solid #dfdfdf;
        border-radius: 1rem;
        min-height: 3rem;
        padding: 0.65rem 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        min-width: max-content;
        background-color: #ffffff;
        margin-left: 0.5rem;
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
    }

    .tax-toggle .form-check-label {
        font-size: 0.92rem;
    }

    .listing-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .listing-card {
        border: 1px solid #ececec !important;
        border-radius: 1.2rem !important;
        overflow: hidden;
        margin-bottom: 1.7rem;
        background: #ffffff;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .listing-link:hover .listing-card,
    .listing-link:focus .listing-card {
        transform: translateY(-6px);
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.1);
        border-color: #e2e2e2 !important;
    }

    .listing-card .card-img-top {
        width: 100%;
        height: 19rem;
        object-fit: cover;
        border-radius: 0 !important;
        transition: transform 0.35s ease;
    }

    .listing-link:hover .card-img-top,
    .listing-link:focus .card-img-top {
        transform: scale(1.03);
    }

    .listing-image-wrap {
        position: relative;
        overflow: hidden;
    }

    .listing-image-wrap::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0));
        pointer-events: none;
    }

    .card-img-overlay {
        opacity: 0;
        transition: opacity 0.25s ease-in-out;
        background: rgba(255, 255, 255, 0.08);
    }

    .listing-link:hover .card-img-overlay {
        opacity: 1;
    }

    .listing-card .card-body {
        padding: 0.95rem 1rem 1rem 1rem !important;
    }

    .listing-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        color: #222222;
        line-height: 1.35;
        letter-spacing: -0.01em;
    }

    .listing-meta {
        margin-top: 0.32rem;
        color: #6a6a6a;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .listing-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-top: 0.75rem;
    }

    .listing-price {
        font-size: 0.96rem;
        color: #222222;
        font-weight: 600;
    }

    .listing-price span {
        font-weight: 400;
        color: #6a6a6a;
    }

    .listing-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.38rem 0.72rem;
        border-radius: 999px;
        background: #f7f7f7;
        border: 1px solid #ececec;
        color: #5d5d5d;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .listing-row {
        margin-top: 0.95rem;
    }

    .empty-state-box {
        max-width: 1120px;
        background: #ffffff;
        border: 1px solid #e9e9e9;
        border-radius: 1.1rem;
        padding: 1.3rem;
        margin: 1rem auto;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .empty-state-box h5 {
        margin-bottom: 0.45rem;
        font-weight: 700;
        color: #222222;
    }

    .empty-state-box p {
        margin-bottom: 0.9rem;
        color: #666666;
    }

    .empty-state-box a {
        font-weight: 600;
    }

    @media (min-width: 992px) {
        .search-filter-box {
            max-width: 1120px;
        }

        .filter-actions {
            justify-content: flex-end;
        }
    }

    @media (max-width: 991px) {
        .search-filter-box {
            padding: 0.95rem;
        }

        .filters-toolbar {
            align-items: flex-start;
        }

        .listing-card .card-img-top {
            height: 17.5rem;
        }
    }

    @media (max-width: 767px) {
        .search-filter-box {
            padding: 0.85rem;
            border-radius: 1.1rem;
        }

        .results-summary {
            margin: 0.2rem auto 0.65rem;
        }

        .active-filters {
            gap: 0.5rem;
            margin-bottom: 0.8rem;
        }

        .filter-chip,
        .clear-all-chip {
            font-size: 0.86rem;
            padding: 0.42rem 0.78rem;
        }

        .filters-toolbar {
            display: block;
            margin-top: 0.85rem;
        }

        #filters {
            gap: 1.15rem;
            padding: 0 0.25rem 0.6rem;
            padding-right: 2rem;
            scroll-padding-inline-end: 2rem;
        }

        .filters-hint {
            display: block;
            font-size: 0.72rem;
            margin: 0.1rem 0 0.65rem 0.25rem;
        }

        .filter {
            min-width: 92px;
        }

        .filter i {
            font-size: 1rem;
        }

        .filter p {
            font-size: 0.72rem;
        }

        .tax-toggle {
            width: fit-content;
            margin: 0.2rem 0 0.75rem 0.25rem;
            padding: 0.7rem 0.9rem;
            font-size: 0.82rem;
        }

        .listing-card {
            margin-bottom: 1.45rem;
            border-radius: 1rem !important;
        }

        .listing-card .card-img-top {
            height: 15.5rem;
        }

        .listing-card .card-body {
            padding: 0.9rem 0.9rem 0.95rem 0.9rem !important;
        }

        .listing-title {
            font-size: 0.97rem;
        }

        .listing-meta {
            font-size: 0.86rem;
        }

        .listing-price {
            font-size: 0.92rem;
        }

        .listing-tag {
            font-size: 0.72rem;
            padding: 0.34rem 0.64rem;
        }

        .listing-row {
            margin-top: 0.8rem;
        }

        .filter-actions {
            flex-direction: column;
        }

        .filter-actions .btn {
            width: 100%;
        }
    }
</style>

<form action="/listings" method="GET" class="search-filter-box">
    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-3">
            <label for="search" class="form-label">Search</label>
            <input
                type="text"
                id="search"
                name="search"
                class="form-control"
                placeholder="Search by title, location, country"
                value="<%= filters && filters.search ? filters.search : '' %>"
            >
        </div>

        <div class="col-6 col-md-3 col-lg-2">
            <label for="minPrice" class="form-label">Min Price</label>
            <input
                type="number"
                id="minPrice"
                name="minPrice"
                min="0"
                class="form-control"
                value="<%= filters && filters.minPrice ? filters.minPrice : '' %>"
            >
        </div>

        <div class="col-6 col-md-3 col-lg-2">
            <label for="maxPrice" class="form-label">Max Price</label>
            <input
                type="number"
                id="maxPrice"
                name="maxPrice"
                min="0"
                class="form-control"
                value="<%= filters && filters.maxPrice ? filters.maxPrice : '' %>"
            >
        </div>

        <div class="col-12 col-md-6 col-lg-2">
            <label for="sort" class="form-label">Sort</label>
            <select id="sort" name="sort" class="form-select">
                <option value="">Newest</option>
                <option value="price_asc" <%= filters && filters.sort === "price_asc" ? "selected" : "" %>>Price: Low to High</option>
                <option value="price_desc" <%= filters && filters.sort === "price_desc" ? "selected" : "" %>>Price: High to Low</option>
            </select>
        </div>

        <div class="col-12 col-md-6 col-lg-3 d-flex align-items-end">
            <div class="filter-actions w-100">
                <button class="btn btn-dark">Apply</button>
                <a href="/listings" class="btn btn-outline-secondary">Clear</a>
            </div>
        </div>
    </div>
</form>

<%
    const currentSearch = filters && filters.search ? filters.search : "";
    const currentMinPrice = filters && filters.minPrice ? filters.minPrice : "";
    const currentMaxPrice = filters && filters.maxPrice ? filters.maxPrice : "";
    const currentSort = filters && filters.sort ? filters.sort : "";
    const currentCategory = filters && filters.category ? filters.category : "";

    const hasSearch = currentSearch.trim() !== "";
    const hasCategory = currentCategory.trim() !== "";
    const hasMinPrice = currentMinPrice !== "";
    const hasMaxPrice = currentMaxPrice !== "";
    const hasSort = currentSort.trim() !== "";

    const hasActiveSearch = hasSearch;
    const hasOtherFilters = hasCategory || hasMinPrice || hasMaxPrice || hasSort;
    const hasActiveFilters = hasSearch || hasCategory || hasMinPrice || hasMaxPrice || hasSort;
%>

<%
    function buildCategoryUrl(categoryName) {
        const params = new URLSearchParams();

        if (hasSearch) params.set("search", currentSearch);
        if (hasMinPrice) params.set("minPrice", currentMinPrice);
        if (hasMaxPrice) params.set("maxPrice", currentMaxPrice);
        if (hasSort) params.set("sort", currentSort);

        if (!hasCategory || currentCategory !== categoryName) {
            params.set("category", categoryName);
        }

        const queryString = params.toString();
        return queryString ? `/listings?${queryString}` : "/listings";
    }

    function buildRemoveFilterUrl(keyToRemove) {
        const params = new URLSearchParams();

        if (hasSearch) params.set("search", currentSearch);
        if (hasCategory) params.set("category", currentCategory);
        if (hasMinPrice) params.set("minPrice", currentMinPrice);
        if (hasMaxPrice) params.set("maxPrice", currentMaxPrice);
        if (hasSort) params.set("sort", currentSort);

        params.delete(keyToRemove);

        const queryString = params.toString();
        return queryString ? `/listings?${queryString}` : "/listings";
    }
%>

<% if (hasActiveFilters) { %>
    <div class="results-summary">
        <% if (hasActiveSearch) { %>
            <h5>Results for "<%= currentSearch %>"</h5>
        <% } else { %>
            <h5>Filtered listings</h5>
        <% } %>

        <p>
            <strong><%= allListings.length %></strong> listing<%= allListings.length === 1 ? "" : "s" %> found.
            <a href="/listings">Clear all filters</a>
        </p>
    </div>
<% } %>

<% if (hasActiveFilters) { %>
    <div class="active-filters">
        <% if (hasSearch) { %>
            <a href="<%= buildRemoveFilterUrl('search') %>" class="filter-chip">
                Search: <%= currentSearch %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasCategory) { %>
            <a href="<%= buildRemoveFilterUrl('category') %>" class="filter-chip">
                Category: <%= currentCategory %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasMinPrice) { %>
            <a href="<%= buildRemoveFilterUrl('minPrice') %>" class="filter-chip">
                Min: ₹<%= Number(currentMinPrice).toLocaleString("en-IN") %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasMaxPrice) { %>
            <a href="<%= buildRemoveFilterUrl('maxPrice') %>" class="filter-chip">
                Max: ₹<%= Number(currentMaxPrice).toLocaleString("en-IN") %> <span>&times;</span>
            </a>
        <% } %>

        <% if (hasSort) { %>
            <a href="<%= buildRemoveFilterUrl('sort') %>" class="filter-chip">
                Sort:
                <%= currentSort === "price_asc" ? "Price: Low to High" : currentSort === "price_desc" ? "Price: High to Low" : currentSort %>
                <span>&times;</span>
            </a>
        <% } %>

        <a href="/listings" class="clear-all-chip">Clear all</a>
    </div>
<% } %>

<div class="filters-toolbar">
    <div id="filters">
        <a href="<%= buildCategoryUrl('Trending') %>" class="filter <%= currentCategory === 'Trending' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>

        <a href="<%= buildCategoryUrl('Rooms') %>" class="filter <%= currentCategory === 'Rooms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </a>

        <a href="<%= buildCategoryUrl('Iconic cities') %>" class="filter <%= currentCategory === 'Iconic cities' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic cities</p>
        </a>

        <a href="<%= buildCategoryUrl('Mountains') %>" class="filter <%= currentCategory === 'Mountains' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>

        <a href="<%= buildCategoryUrl('Castles') %>" class="filter <%= currentCategory === 'Castles' ? 'active-filter' : '' %>">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </a>

        <a href="<%= buildCategoryUrl('Amazing Pools') %>" class="filter <%= currentCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </a>

        <a href="<%= buildCategoryUrl('Camping') %>" class="filter <%= currentCategory === 'Camping' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>

        <a href="<%= buildCategoryUrl('Farms') %>" class="filter <%= currentCategory === 'Farms' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-tractor"></i></div>
            <p>Farms</p>
        </a>

        <a href="<%= buildCategoryUrl('Arctic') %>" class="filter <%= currentCategory === 'Arctic' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>

        <a href="<%= buildCategoryUrl('Domes') %>" class="filter <%= currentCategory === 'Domes' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-landmark-dome"></i></div>
            <p>Domes</p>
        </a>

        <a href="<%= buildCategoryUrl('Beaches') %>" class="filter <%= currentCategory === 'Beaches' ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-umbrella-beach"></i></div>
            <p>Beaches</p>
        </a>
    </div>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>

<p class="filters-hint">Swipe for more filters →</p>

<% if(allListings.length === 0) { %>
    <div class="empty-state-box">
        <% if (hasActiveSearch) { %>
            <h5>No listings found for "<%= currentSearch %>"</h5>
            <p>Try a different keyword, remove some filters, or browse all listings instead.</p>
        <% } else { %>
            <h5>No listings found</h5>
            <p>Try changing your search or filter values.</p>
        <% } %>
        <a href="/listings" class="btn btn-outline-dark btn-sm">Browse all listings</a>
    </div>
<% } %>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 listing-row">
    <% for(let listing of allListings) { %>
        <% const listingImageUrl = listing.image && (listing.image.url || listing.image.secure_url || listing.image.path || listing.image); %>
        <div class="col">
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card listing-card h-100">
                    <div class="listing-image-wrap">
                        <img
                            src="<%= listingImageUrl %>"
                            class="card-img-top"
                            alt="listing_image"
                        >
                        <div class="card-img-overlay"></div>
                    </div>

                    <div class="card-body">
                        <h5 class="listing-title"><%= listing.title %></h5>

                        <p class="listing-meta">
                            <%= listing.location %>, <%= listing.country %>
                        </p>

                        <div class="listing-bottom">
                            <p class="listing-price">
                                &#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                <span>/ night</span>
                                <i class="tax-info">&nbsp; +18% GST</i>
                            </p>

                            <% if (listing.category) { %>
                                <span class="listing-tag"><%= listing.category %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (let info of taxInfo) {
            if (info.style.display != "inline") {
                info.style.display = "inline";
            } else {
                info.style.display = "none";
            }
        }
    });
</script>