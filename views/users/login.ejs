<% layout("/layouts/boilerplate") %>

<section class="auth-section">
    <div class="auth-shell">
        <div class="auth-card">
            <div class="auth-copy">
                <span class="auth-eyebrow">Welcome back</span>
                <h1 class="auth-title">Login to Stayora</h1>
                <p class="auth-subtitle">
                    Continue exploring stays, managing bookings, and saving your favorite places.
                </p>
            </div>

            <form action="/login" method="POST" class="needs-validation auth-form" novalidate>

                <!-- Username -->
                <div class="auth-field">
                    <label for="username" class="form-label auth-label">Username</label>
                    <input
                        name="username"
                        type="text"
                        id="username"
                        class="form-control auth-input"
                        value="<%= formData && formData.username ? formData.username : '' %>"
                        autocomplete="username"
                        required
                    />
                    <div class="invalid-feedback">
                        Please enter your username.
                    </div>
                </div>

                <!-- Password -->
                <div class="auth-field">
                    <label for="password" class="form-label auth-label">Password</label>
                    <input
                        name="password"
                        type="password"
                        id="password"
                        class="form-control auth-input"
                        autocomplete="current-password"
                        required
                    />
                    <div class="invalid-feedback">
                        Please enter your password.
                    </div>
                </div>

                <button class="btn auth-submit-btn">Login</button>

                <p class="auth-switch-text">
                    New to Stayora?
                    <a href="/signup" class="auth-switch-link">Create an account</a>
                </p>
            </form>
        </div>
    </div>
</section>