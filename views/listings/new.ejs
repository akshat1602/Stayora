<!-- EJS-mate -->
<% layout("/layouts/boilerplate") %>

<div class="new-wrapper mt-3">
    <div class="new-form-container form-shell">
        <div class="form-page-header">
            <span class="form-page-eyebrow">Host on Stayora</span>
            <h3>Create a New Listing</h3>
            <p class="form-page-subtitle">
                Add the essentials below so guests can discover your stay more easily.
            </p>
        </div>

        <form action="/listings" method="POST" novalidate class="needs-validation stayora-form" enctype="multipart/form-data">
            <!-- Title of listing -->
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input
                    name="listing[title]"
                    placeholder="enter title"
                    type="text"
                    class="form-control <%= error && error.errors && error.errors.title ? 'is-invalid' : '' %>"
                    value="<%= listing && listing.title ? listing.title : '' %>"
                    required
                />
                <div class="invalid-feedback">
                    Please enter a title.
                </div>
                <div class="valid-feedback">
                    Title looks good!
                </div>
            </div>

            <!-- Description of listing -->
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea
                    name="listing[description]"
                    placeholder="enter description"
                    class="form-control new-textarea <%= error && error.errors && error.errors.description ? 'is-invalid' : '' %>"
                    required
                ><%= listing && listing.description ? listing.description : '' %></textarea>
                <div class="invalid-feedback">
                    Please enter a description.
                </div>
                <div class="valid-feedback">
                    Description looks good!
                </div>
            </div>

            <!-- Category of listing -->
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select
                    name="listing[category]"
                    class="form-select <%= error && error.errors && error.errors.category ? 'is-invalid' : '' %>"
                    required
                >
                    <option value="">Select a category</option>
                    <option value="Trending" <%= listing && listing.category === "Trending" ? "selected" : "" %>>Trending</option>
                    <option value="Rooms" <%= listing && listing.category === "Rooms" ? "selected" : "" %>>Rooms</option>
                    <option value="Iconic cities" <%= listing && listing.category === "Iconic cities" ? "selected" : "" %>>Iconic cities</option>
                    <option value="Mountains" <%= listing && listing.category === "Mountains" ? "selected" : "" %>>Mountains</option>
                    <option value="Castles" <%= listing && listing.category === "Castles" ? "selected" : "" %>>Castles</option>
                    <option value="Amazing Pools" <%= listing && listing.category === "Amazing Pools" ? "selected" : "" %>>Amazing Pools</option>
                    <option value="Camping" <%= listing && listing.category === "Camping" ? "selected" : "" %>>Camping</option>
                    <option value="Farms" <%= listing && listing.category === "Farms" ? "selected" : "" %>>Farms</option>
                    <option value="Arctic" <%= listing && listing.category === "Arctic" ? "selected" : "" %>>Arctic</option>
                    <option value="Domes" <%= listing && listing.category === "Domes" ? "selected" : "" %>>Domes</option>
                    <option value="Beaches" <%= listing && listing.category === "Beaches" ? "selected" : "" %>>Beaches</option>
                </select>
                <div class="invalid-feedback">
                    Please select a category.
                </div>
                <div class="valid-feedback">
                    Category looks good!
                </div>
            </div>

            <!-- Image Link of listing -->
            <div class="mb-3">
                <label for="image" class="form-label">Upload Listing Image</label>
                <img id="newImagePreview" src="" class="card-img-top new-preview-img mb-3" alt="preview" style="display:none;">
                <input
                    id="newImageInput"
                    name="listing[image]"
                    type="file"
                    class="form-control"
                    required
                >
                <div class="form-helper-text">Choose a clear cover image that represents the stay well.</div>
            </div>

            <!-- Price and country of listing -->
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input
                        name="listing[price]"
                        placeholder="enter price"
                        type="number"
                        min="1"
                        step="1"
                        class="form-control <%= error && error.errors && error.errors.price ? 'is-invalid' : '' %>"
                        value="<%= listing && (listing.price || listing.price === 0) ? listing.price : '' %>"
                        required
                    />
                    <div class="invalid-feedback">
                        Please enter a valid non-negative price.
                    </div>
                    <div class="valid-feedback">
                        Price looks good!
                    </div>
                </div>

                <div class="col-12 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input
                        name="listing[country]"
                        placeholder="enter country"
                        type="text"
                        class="form-control <%= error && error.errors && error.errors.country ? 'is-invalid' : '' %>"
                        value="<%= listing && listing.country ? listing.country : '' %>"
                        required
                    />
                    <div class="invalid-feedback">
                        Please enter a country.
                    </div>
                    <div class="valid-feedback">
                        Country looks good!
                    </div>
                </div>
            </div>

            <!-- Location of listing -->
            <div class="mb-3 mt-3">
                <label for="location" class="form-label">Location</label>
                <input
                    name="listing[location]"
                    placeholder="enter location"
                    type="text"
                    class="form-control <%= error && error.errors && error.errors.location ? 'is-invalid' : '' %>"
                    value="<%= listing && listing.location ? listing.location : '' %>"
                    required
                />
                <div class="invalid-feedback">
                    Please enter a location.
                </div>
                <div class="valid-feedback">
                    Location looks good!
                </div>
            </div>

            <button class="btn btn-dark add-btn mt-3 new-submit-btn">Add Listing</button>
        </form>
    </div>
</div>

<script>
    const newImageInput = document.getElementById('newImageInput');
    const newPreview = document.getElementById('newImagePreview');

    if (newImageInput) {
        newImageInput.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(evt) {
                newPreview.src = evt.target.result;
                newPreview.style.display = 'block';
            }
            reader.readAsDataURL(file);
        });
    }
</script>